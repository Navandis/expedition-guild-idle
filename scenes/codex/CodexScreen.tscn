[gd_scene format=3]

; Codex screen layout keeps BottomNavBar as a fixed footer.
; The scroll area above it absorbs tall discovery content so the nav never clips.

[ext_resource type="Script" path="res://scripts/ui/CodexController.gd" id="1_codex"]
[ext_resource type="PackedScene" path="res://scenes/components/BottomNavBar.tscn" id="2_nav"]

[node name="CodexScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_codex")

[node name="SafeArea" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="RootColumn" type="VBoxContainer" parent="SafeArea"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="TitleLabel" type="Label" parent="SafeArea/RootColumn"]
layout_mode = 2
text = "Codex Discoveries"
horizontal_alignment = 1

[node name="HeaderPanel" type="PanelContainer" parent="SafeArea/RootColumn"]
layout_mode = 2

[node name="HeaderRows" type="VBoxContainer" parent="SafeArea/RootColumn/HeaderPanel"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="SummaryLabel" type="Label" parent="SafeArea/RootColumn/HeaderPanel/HeaderRows"]
layout_mode = 2
text = "Discoveries unlocked: 0"

[node name="HintLabel" type="Label" parent="SafeArea/RootColumn/HeaderPanel/HeaderRows"]
layout_mode = 2
text = "Collect expedition rewards to discover site types."
autowrap_mode = 3

[node name="EntriesScroll" type="ScrollContainer" parent="SafeArea/RootColumn"]
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="EntriesPanel" type="PanelContainer" parent="SafeArea/RootColumn/EntriesScroll"]
layout_mode = 2

[node name="EntriesRows" type="VBoxContainer" parent="SafeArea/RootColumn/EntriesScroll/EntriesPanel"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="EntriesHeader" type="Label" parent="SafeArea/RootColumn/EntriesScroll/EntriesPanel/EntriesRows"]
layout_mode = 2
text = "Discovered Site Types"

[node name="EntriesListLabel" type="Label" parent="SafeArea/RootColumn/EntriesScroll/EntriesPanel/EntriesRows"]
layout_mode = 2
text = "No discoveries yet."
autowrap_mode = 3

[node name="BackButton" type="Button" parent="SafeArea/RootColumn"]
custom_minimum_size = Vector2(0, 52)
layout_mode = 2
text = "Back to Guild Hall"

[node name="BottomNavBar" parent="SafeArea/RootColumn" instance=ExtResource("2_nav")]
layout_mode = 2
