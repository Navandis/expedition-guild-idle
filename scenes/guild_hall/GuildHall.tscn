[gd_scene format=3]

; Guild Hall home screen for day-2 shell flow.

[ext_resource type="Script" path="res://scripts/ui/GuildHallController.gd" id="1_72fw3"]

[node name="GuildHall" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_72fw3")

[node name="SafeArea" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="RootColumn" type="VBoxContainer" parent="SafeArea"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="TitleLabel" type="Label" parent="SafeArea/RootColumn"]
layout_mode = 2
text = "Guild Hall"
horizontal_alignment = 1

[node name="ResourcesPanel" type="PanelContainer" parent="SafeArea/RootColumn"]
layout_mode = 2

[node name="ResourceRows" type="VBoxContainer" parent="SafeArea/RootColumn/ResourcesPanel"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="ResourcesHeader" type="Label" parent="SafeArea/RootColumn/ResourcesPanel/ResourceRows"]
layout_mode = 2
text = "Resources (Placeholder)"

[node name="GoldLabel" type="Label" parent="SafeArea/RootColumn/ResourcesPanel/ResourceRows"]
layout_mode = 2
text = "Gold: 1,250"

[node name="SuppliesLabel" type="Label" parent="SafeArea/RootColumn/ResourcesPanel/ResourceRows"]
layout_mode = 2
text = "Supplies: 80"

[node name="MoraleLabel" type="Label" parent="SafeArea/RootColumn/ResourcesPanel/ResourceRows"]
layout_mode = 2
text = "Guild Morale: Stable"

[node name="OpenBoardButton" type="Button" parent="SafeArea/RootColumn"]
custom_minimum_size = Vector2(0, 56)
layout_mode = 2
text = "Open Expedition Board"

[node name="ActiveExpeditionPanel" type="PanelContainer" parent="SafeArea/RootColumn"]
custom_minimum_size = Vector2(0, 140)
layout_mode = 2
size_flags_vertical = 3

[node name="ActiveRows" type="VBoxContainer" parent="SafeArea/RootColumn/ActiveExpeditionPanel"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="ActiveHeader" type="Label" parent="SafeArea/RootColumn/ActiveExpeditionPanel/ActiveRows"]
layout_mode = 2
text = "Active Expedition Status"

[node name="StatusLabel" type="Label" parent="SafeArea/RootColumn/ActiveExpeditionPanel/ActiveRows"]
layout_mode = 2
text = "No active expedition yet."
autowrap_mode = 3
