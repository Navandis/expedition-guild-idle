[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/ExpeditionCardView.gd" id="1_kipng"]

; Reusable expedition offer card for Expedition Board middle bucket.
[node name="ExpeditionCard" type="Button"]
custom_minimum_size = Vector2(0, 110)
size_flags_horizontal = 3
text = ""
script = ExtResource("1_kipng")

; Margin wrapper keeps content compact and readable.
[node name="CardContent" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 8
mouse_filter = 2

[node name="Rows" type="VBoxContainer" parent="CardContent"]
layout_mode = 2
theme_override_constants/separation = 4

; Placeholder site image zone keeps cards comparison-friendly while preserving
; room for core text stats.
[node name="SiteImage" type="TextureRect" parent="CardContent/Rows"]
custom_minimum_size = Vector2(0, 34)
layout_mode = 2
texture_filter = 1
expand_mode = 1
stretch_mode = 5

[node name="DisplayNameLabel" type="Label" parent="CardContent/Rows" unique_name_in_owner=true]
layout_mode = 2
text = "Display Name"

[node name="DurationLabel" type="Label" parent="CardContent/Rows" unique_name_in_owner=true]
layout_mode = 2
text = "Duration: --"

[node name="RiskLabel" type="Label" parent="CardContent/Rows" unique_name_in_owner=true]
layout_mode = 2
text = "Risk: --"

[node name="RewardLabel" type="Label" parent="CardContent/Rows" unique_name_in_owner=true]
layout_mode = 2
text = "Reward: --"

[node name="HazardLabel" type="Label" parent="CardContent/Rows" unique_name_in_owner=true]
layout_mode = 2
text = "Hazard: --"
